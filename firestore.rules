rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.xp is int && data.xp >= 0 &&
             data.level is int && data.level >= 1 &&
             (!('title' in data) || (data.title is string && data.title.size() <= 30));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().xp == 0 && incoming().level == 1;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Stats (XP/Level can only go up or stay same)
        (incoming().xp >= existing().xp && incoming().level >= existing().level &&
         incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'title', 'lastActive', 'biography', 'displayName']))
      );
    }

    // Mentor Progress Validation
    function isValidMentorProgress(data) {
      return data.mentorId is string &&
             data.level is int && data.level >= 0 &&
             data.xp is int && data.xp >= 0;
    }

    match /users/{userId}/mentors/{mentorId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidMentorProgress(incoming());
    }

    // Quest Rules
    match /quests/{questId} {
      allow get, list: if isSignedIn();
      // Admin only write
      allow write: if false; 
    }

    // User Quest Progress
    function isValidUserQuest(data) {
      return data.userId == request.auth.uid &&
             data.questId is string &&
             data.status in ['started', 'submitted', 'completed', 'failed'] &&
             (!('submission' in data) || data.submission is string) &&
             (!('feedback' in data) || data.feedback is string);
    }

    match /users/{userId}/quests/{questId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserQuest(incoming());
      allow update: if isOwner(userId) && isValidUserQuest(incoming()) && (
        // Prevent changing userId or questId
        incoming().userId == existing().userId &&
        incoming().questId == existing().questId
      );
    }
  }
}
